# ===== 必填 =====
BOT_TOKEN=your-telegram-bot-token
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-5.4

# ===== Gmail OAuth（可选，不填则 Gmail 功能不可用）=====
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_REDIRECT_URL=http://localhost

# ===== 存储 =====
DB_DSN=root:password@tcp(127.0.0.1:3306)/gmailbot?parseTime=true&charset=utf8mb4&loc=UTC
MEMORY_ROOT=./data/memory
KNOWLEDGE_ROOT=./data/knowledge

# ===== AI 参数 =====
AI_TIMEOUT_SEC=360
AI_TOOL_MAX_STEPS=6
AI_CONTEXT_WARN_TOKENS=0
AI_CONTEXT_MAX_TOKENS=0
AI_CONTEXT_KEEP_RECENT=6
AI_PROVIDER_TYPE=openai_compat
# AI_FALLBACK_PROVIDERS=[{"name":"backup","type":"openai_compat","base_url":"https://api.deepseek.com/v1","api_key":"sk-xxx","model":"deepseek-chat"}]

# ===== Telegram =====
TELEGRAM_TIMEOUT_SEC=10

# ===== 频率限制（0=不限制）=====
MESSAGE_RATE_LIMIT_PER_MIN=0

# ===== 人格 =====
DEFAULT_PERSONA=gmail

# ===== 配置热重载 =====
CONFIG_WATCH_ENABLED=true
CONFIG_WATCH_DEBOUNCE_MS=800

# ===== Webhook（可选）=====
# WEBHOOK_ADDR=:29110
# WEBHOOK_SECRET=your-webhook-secret

# ===== Dashboard（可选）=====
# DASHBOARD_ADDR=:29111
# DASHBOARD_AUTH=your-dashboard-auth-token

# ===== WebUI（可选）=====
# WEBUI_ADDR=:29112

# ===== 飞书（可选）=====
# LARK_APP_ID=
# LARK_APP_SECRET=
# LARK_BOT_NAME=

# ===== QQ 官方（可选）=====
# QQ_APPID=
# QQ_SECRET=
# QQ_ENABLE_GROUP=true

# ===== 测试数据库（必填）=====
# TEST_DB_DSN=root:test@tcp(127.0.0.1:3306)/gmailbot_test?parseTime=true&charset=utf8mb4&loc=UTC

# ===== MCP（可选，JSON 格式）=====
# MCP_SERVERS=[{"name":"fs","command":"npx","args":["-y","@anthropic/mcp-filesystem"]}]
